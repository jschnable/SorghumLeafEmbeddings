{
for(e in present_environments)
{
pvals <- list(c(pvals,
e = wilcox.test(as.formula(str_c(trait_str, ' ~ `', marker_str, '`')),
data = .data,
subset = .data[['environment']]==e,
conf.int = TRUE)$p.value))
