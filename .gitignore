# Generated analysis artifacts live in data/generatable/ and are not committed
# (except the README documenting what each generatable file is).
data/generatable/*
!data/generatable/README.md

# Large external-source assets (raw images, SAM3/DINOv2 weights, marker VCF/PLINK)
# are obtained separately and must never be committed. Only the README files that
# document where to get each asset are tracked.
data/externalsourcerequired/**
!data/externalsourcerequired/**/
!data/externalsourcerequired/README.md
!data/externalsourcerequired/**/README.txt

*.npz
__pycache__/
*.py[cod]
.~lock.*
PEER_REVIEW.md
